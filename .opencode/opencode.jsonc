{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "opencode": {
      "options": {},
    },
  },
  "permission": {
    "edit": {
      "packages/opencode/migration/*": "deny",
    },
  },
  "mcp": {},
  "tools": {
    "github-triage": true,
    "github-pr-search": true,
    "research-websearch": true,
    "websearch": true,
    "codesearch": true,
    "searxng-search": true,
    "browser-navigate": true,
    "browser-click": true,
    "browser-type": true,
    "browser-snapshot": true,
    "browser-screenshot": true,
    "browser-wait": true,
  },
  "plugin": ["opencode-gemini-auth"],
}
